# Anthropic API key — required for agents to reason (works even in dry_run mode).
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Shopify app credentials — see README "Connect your Shopify store".
# Apps are created in the Dev Dashboard (dev.shopify.com); copy the Client ID
# and Client secret from the app's Settings page. shopagent exchanges them for
# short-lived Admin API tokens automatically (cached in .shopify_token.json).
# Leave blank to run against the built-in mock store.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Legacy alternative: a permanent shpat_ Admin API token from a custom app
# created before 2026. If set, it takes precedence over client credentials.
SHOPIFY_ACCESS_TOKEN=

# CJ Dropshipping API credentials — see README "Connect CJ Dropshipping".
# Leave blank to run against the built-in mock supplier catalog.
CJ_EMAIL=
CJ_API_KEY=

# Amazon SP-API credentials — see README "Adding the Amazon channel".
# From your self-authorized app in Seller Central (Partner Network -> Develop
# Apps): LWA Client ID + Client Secret, and the refresh token shown when you
# authorize the app. AMZ_SELLER_ID is your Merchant Token (Settings ->
# Account Info -> Merchant Token). Leave blank to use the mock Amazon backend.
AMZ_CLIENT_ID=
AMZ_CLIENT_SECRET=
AMZ_REFRESH_TOKEN=
AMZ_SELLER_ID=
