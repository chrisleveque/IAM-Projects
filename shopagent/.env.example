# Anthropic API key — required for agents to reason (works even in dry_run mode).
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Shopify custom app credentials — see README "Connect your Shopify store".
# Leave blank to run against the built-in mock store.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=

# CJ Dropshipping API credentials — see README "Connect CJ Dropshipping".
# Leave blank to run against the built-in mock supplier catalog.
CJ_EMAIL=
CJ_API_KEY=
