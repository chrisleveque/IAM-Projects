# Anthropic API key — required for the agents to reason (even in dry_run mode).
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Stock footage APIs — both free. Leave blank to use the built-in mock footage
# (generated test-pattern clips) so the pipeline still renders end to end.
# Pexels: https://www.pexels.com/api/    (200 requests/hour)
# Pixabay: https://pixabay.com/api/docs/ (100 requests/minute)
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ElevenLabs — OPTIONAL paid voice upgrade. The default voice is Microsoft
# Edge neural TTS (free, no key). Set both to use ElevenLabs instead, and set
# tts.provider: elevenlabs in the preset.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# YouTube upload — path to the OAuth client secrets JSON downloaded from
# Google Cloud Console (APIs & Services > Credentials > OAuth client ID,
# type "Desktop app"). Also configurable as paths.youtube_client_secrets.
# Then run: fitagent auth youtube
YOUTUBE_CLIENT_SECRETS=client_secret.json
